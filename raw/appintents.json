{
  "abstract": [
    {
      "type": "text",
      "text": "Make content and actions discoverable by Apple Intelligence and support system experiences like Siri, Spotlight, Shortcuts, and widgets."
    }
  ],
  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "anchor": "Overview",
          "type": "heading",
          "level": 2,
          "text": "Overview"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "Make your app’s actions and data available outside your app using the App Intents framework.",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "Every app has code to perform specific actions, such as playing music or displaying",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "photos. Apps also have data, such as songs or photos, that people might want to use outside",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "your app."
            }
          ]
        },
        {
          "inlineContent": [
            {
              "identifier": "app-intents-hero",
              "type": "image"
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "With App Intents, you express your app’s actions and data in a structured",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "way that makes them discoverable by Apple Intelligence and provides deeper integration with system features people use frequently. For example:",
              "type": "text"
            }
          ]
        },
        {
          "items": [
            {
              "content": [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "People can interact with your app’s content through Siri."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "content": [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Spotlight helps people navigate to your data directly from search results."
                    }
                  ]
                }
              ]
            },
            {
              "content": [
                {
                  "inlineContent": [
                    {
                      "text": "The Shortcuts app helps people configure workflows that include your app’s actions.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "content": [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "text": "People can configure Apple Pencil or the Action button on iPhone to perform your app’s actions when pressed.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            {
              "content": [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "isActive": true,
                      "type": "reference",
                      "identifier": "doc://com.apple.documentation/documentation/WidgetKit",
                      "overridingTitleInlineContent": [
                        {
                          "type": "text",
                          "text": "Widgets"
                        }
                      ],
                      "overridingTitle": "Widgets"
                    },
                    {
                      "type": "text",
                      "text": ", "
                    },
                    {
                      "isActive": true,
                      "overridingTitleInlineContent": [
                        {
                          "type": "text",
                          "text": "controls"
                        }
                      ],
                      "identifier": "doc://com.apple.documentation/documentation/WidgetKit/Controls-Collection",
                      "overridingTitle": "controls",
                      "type": "reference"
                    },
                    {
                      "text": ", and ",
                      "type": "text"
                    },
                    {
                      "overridingTitleInlineContent": [
                        {
                          "type": "text",
                          "text": "Live Activities"
                        }
                      ],
                      "overridingTitle": "Live Activities",
                      "identifier": "doc://com.apple.documentation/documentation/ActivityKit",
                      "type": "reference",
                      "isActive": true
                    },
                    {
                      "type": "text",
                      "text": " can use your app’s actions to perform relevant tasks."
                    }
                  ]
                }
              ]
            },
            {
              "content": [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "text": "You can define custom Focus modes, and respond to Focus changes.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          ],
          "type": "unorderedList"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "Use this framework to declare the actions your app performs as one or more "
            },
            {
              "inlineContent": [
                {
                  "type": "text",
                  "text": "app intents"
                }
              ],
              "type": "emphasis"
            },
            {
              "text": ". You can also create",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "inlineContent": [
                {
                  "text": "app entities",
                  "type": "text"
                }
              ],
              "type": "emphasis"
            },
            {
              "text": " and ",
              "type": "text"
            },
            {
              "inlineContent": [
                {
                  "text": "app enums",
                  "type": "text"
                }
              ],
              "type": "emphasis"
            },
            {
              "text": " to make your app’s key data types available to the system. For example, a",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "music app might define entities for the songs and albums it manages, and define an app intent to play them."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "During compilation, the compiler generates information that Apple Intelligence, Siri, and other system features need to discover",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "and use your intents, entities, and app enum types.",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "For design guidance on how to implement features that involve ",
              "type": "text"
            },
            {
              "identifier": "doc://com.apple.documentation/design/Human-Interface-Guidelines/widgets",
              "isActive": true,
              "overridingTitle": "Widgets",
              "overridingTitleInlineContent": [
                {
                  "text": "Widgets",
                  "type": "text"
                }
              ],
              "type": "reference"
            },
            {
              "type": "text",
              "text": ","
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "overridingTitleInlineContent": [
                {
                  "text": "Controls",
                  "type": "text"
                }
              ],
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.documentation/design/Human-Interface-Guidelines/controls",
              "overridingTitle": "Controls"
            },
            {
              "type": "text",
              "text": ","
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "overridingTitleInlineContent": [
                {
                  "type": "text",
                  "text": "App Shortcuts"
                }
              ],
              "identifier": "doc://com.apple.documentation/design/Human-Interface-Guidelines/app-shortcuts",
              "isActive": true,
              "type": "reference",
              "overridingTitle": "App Shortcuts"
            },
            {
              "type": "text",
              "text": ","
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "overridingTitleInlineContent": [
                {
                  "text": "Siri",
                  "type": "text"
                }
              ],
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.documentation/design/Human-Interface-Guidelines/siri",
              "overridingTitle": "Siri"
            },
            {
              "type": "text",
              "text": ", or the"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "identifier": "doc://com.apple.documentation/design/Human-Interface-Guidelines/action-button",
              "overridingTitleInlineContent": [
                {
                  "type": "text",
                  "text": "Action button"
                }
              ],
              "type": "reference",
              "isActive": true,
              "overridingTitle": "Action button"
            },
            {
              "text": ",",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "see "
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.documentation/design/human-interface-guidelines",
              "isActive": true,
              "overridingTitle": "Human Interface Guidelines",
              "overridingTitleInlineContent": [
                {
                  "type": "text",
                  "text": "Human Interface Guidelines"
                }
              ]
            },
            {
              "type": "text",
              "text": "."
            }
          ]
        }
      ]
    }
  ],
