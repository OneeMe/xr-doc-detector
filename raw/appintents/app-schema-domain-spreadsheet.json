  "primaryContentSections": [
    {
      "content": [
        {
          "type": "heading",
          "level": 2,
          "text": "Overview",
          "anchor": "overview"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "code": ".spreadsheet",
              "type": "codeVoice"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "structured representation for common spreadsheet actions and content."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "Apply schemas in the ",
              "type": "text"
            },
            {
              "type": "codeVoice",
              "code": ".spreadsheet"
            },
            {
              "text": " domain to make your spreadsheet app’s functionality available as actions in the Shortcuts app.",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Schemas in this domain don’t make your conforming types discoverable by Apple Intelligence and Siri."
            }
          ]
        },
        {
          "name": "Tip",
          "style": "tip",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "type": "text",
                  "text": "Xcode generates a template implementation when you type "
                },
                {
                  "code": "spreadsheet_",
                  "type": "codeVoice"
                },
                {
                  "text": " and select a schema from the suggestions list.",
                  "type": "text"
                }
              ]
            }
          ],
          "type": "aside"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "For more information about app schemas, see "
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/app-schema-domains"
            },
            {
              "type": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
