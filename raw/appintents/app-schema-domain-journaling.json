  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "type": "heading",
          "text": "Overview",
          "level": 2,
          "anchor": "overview"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "code": ".journal",
              "type": "codeVoice"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "structured representation for common journaling actions and content.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "type": "codeVoice",
              "code": ".journal"
            },
            {
              "text": " domain to make your journaling app’s functionality available as actions in the Shortcuts app.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Schemas in this domain don’t make your conforming types discoverable by Apple Intelligence and Siri."
            }
          ]
        },
        {
          "name": "Tip",
          "content": [
            {
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "type": "codeVoice",
                  "code": "journal_"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ],
              "type": "paragraph"
            }
          ],
          "type": "aside",
          "style": "tip"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "For more information about app schemas, see ",
              "type": "text"
            },
            {
              "type": "reference",
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/app-schema-domains"
            },
            {
              "type": "text",
              "text": "."
            }
          ]
        }
      ]
    }
