  "primaryContentSections": [
    {
      "content": [
        {
          "level": 2,
          "type": "heading",
          "text": "Overview",
          "anchor": "overview"
        },
        {
          "inlineContent": [
            {
              "text": "The ",
              "type": "text"
            },
            {
              "type": "codeVoice",
              "code": ".browser"
            },
            {
              "type": "text",
              "text": " domain defines app schemas that provide a"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "structured representation for common browsing actions and content."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "Apply schemas in the ",
              "type": "text"
            },
            {
              "type": "codeVoice",
              "code": ".browser"
            },
            {
              "text": " domain to make your browser’s functionality available as actions in the Shortcuts app.",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Schemas in this domain don’t make your conforming types discoverable by Apple Intelligence and Siri."
            }
          ],
          "type": "paragraph"
        },
        {
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "type": "text",
                  "text": "Xcode generates a template implementation when you type "
                },
                {
                  "code": "browser_",
                  "type": "codeVoice"
                },
                {
                  "text": " and select a schema from the suggestions list.",
                  "type": "text"
                }
              ]
            }
          ],
          "type": "aside",
          "name": "Tip",
          "style": "tip"
        },
        {
          "inlineContent": [
            {
              "text": "For more information about app schemas, see ",
              "type": "text"
            },
            {
              "type": "reference",
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/app-schema-domains"
            },
            {
              "text": ".",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
