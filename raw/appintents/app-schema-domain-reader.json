{
  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "text": "Overview",
          "type": "heading",
          "anchor": "overview",
          "level": 2
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "The ",
              "type": "text"
            },
            {
              "code": ".reader",
              "type": "codeVoice"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "structured representation for common document reading actions and content."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "code": ".reader",
              "type": "codeVoice"
            },
            {
              "type": "text",
              "text": " domain to make your document reader’s functionality available as actions in the Shortcuts app."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Schemas in this domain don’t make your conforming types discoverable by Apple Intelligence and Siri."
            }
          ]
        },
        {
          "type": "aside",
          "style": "tip",
          "content": [
            {
              "inlineContent": [
                {
                  "type": "text",
                  "text": "Xcode generates a template implementation when you type "
                },
                {
                  "code": "reader_",
                  "type": "codeVoice"
                },
                {
                  "text": " and select a schema from the suggestions list.",
                  "type": "text"
                }
              ],
              "type": "paragraph"
            }
          ],
          "name": "Tip"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "For more information about app schemas, see "
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/app-schema-domains"
            },
            {
              "type": "text",
              "text": "."
            }
          ]
        }
      ]
    }
  ],
