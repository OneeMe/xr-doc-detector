  "primaryContentSections": [
    {
      "content": [
        {
          "anchor": "Overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "You can make widgets, Live Activities, and other experiences interactive by adding buttons and"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "toggles to their interfaces. When someone interacts with one of those controls, you respond by"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "creating an app intent. Use those app intents to perform the associated actions in your app.",
              "type": "text"
            }
          ]
        }
      ],
      "kind": "content"
    }
  ],
