  "abstract": [
    {
      "text": "Resolve the parameters of your app intents, and extend the standard resolution",
      "type": "text"
    },
    {
      "type": "text",
      "text": " "
    },
    {
      "type": "text",
      "text": "types to include your app’s custom types."
    }
  ],
