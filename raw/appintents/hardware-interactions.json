  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "anchor": "Overview",
          "text": "Overview",
          "type": "heading",
          "level": 2
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "On supported iPhone models, people can run custom actions quickly using the Action button. This button",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "is configurable in Settings, so people can assign any App Shortcuts you create to quickly access your"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "app’s features. In select regions, people can also place custom actions on the side button of an iPhone",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "to launch your conversational app.",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "On supported Apple Watch models, people can start a workout or dive session using the device’s Action button.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "This button is also configurable in Settings, and supports app intents that support the "
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/StartWorkoutIntent"
            },
            {
              "type": "text",
              "text": ""
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "or "
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/StartDiveIntent",
              "isActive": true
            },
            {
              "text": " protocol.",
              "type": "text"
            }
          ]
        },
        {
          "inlineContent": [
            {
              "text": "For more information about how to create App Shortcuts, see ",
              "type": "text"
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/app-shortcuts",
              "isActive": true
            },
            {
              "type": "text",
              "text": ". For design guidance related"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "to the Action button, see "
            },
            {
              "identifier": "doc://com.apple.documentation/design/Human-Interface-Guidelines/action-button",
              "overridingTitleInlineContent": [
                {
                  "type": "text",
                  "text": "Human Interface Guidelines > Action button"
                }
              ],
              "type": "reference",
              "isActive": true,
              "overridingTitle": "Human Interface Guidelines > Action button"
            },
            {
              "type": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ]
    }
  ],
