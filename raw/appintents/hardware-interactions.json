    {
      "type": "text",
      "text": "Run your App Shortcuts from the Action button on iPhone or Apple Watch, or launch your own conversational app from the"
    },
    {
      "text": " ",
      "type": "text"
    },
    {
      "type": "text",
      "text": "side button on iPhone."
    }
