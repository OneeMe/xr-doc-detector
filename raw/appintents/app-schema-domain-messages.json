  "kind": "article",
  "abstract": [
    {
      "text": "Make your messaging app’s actions available to Apple Intelligence and Siri by adopting schemas for common messaging actions.",
      "type": "text"
    }
  ],
  "variants": [
    {
      "paths": [
        "/documentation/appintents/app-schema-domain-messages"
      ],
      "traits": [
        {
          "interfaceLanguage": "swift"
        }
      ]
    }
  ],
  "sections": [],
  "primaryContentSections": [
    {
      "content": [
        {
          "anchor": "overview",
          "text": "Overview",
          "level": 2,
          "type": "heading"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "type": "codeVoice",
              "code": ".messages"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "structured representation for common messaging actions and content.",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "code": ".messages",
              "type": "codeVoice"
            },
            {
              "text": " domain to make your app’s messaging functionality available to Apple Intelligence and Siri.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Each schema defines the requirements for intents, parameters, and results so people get a consistent experience across messaging apps."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "For example, a person can send a message on different apps that support the"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MessagesIntent/sendMessage",
              "type": "reference"
            },
            {
              "text": " schema with the same phrases.",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "The following table maps example phrases that apply to each schema.",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "Your app needs to support all of these schemas when it supports any one of them.",
              "type": "text"
            }
          ]
        },
        {
          "header": "row",
          "type": "table",
          "rows": [
            [
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Messages intent schemas"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "text": "Example phrases",
                      "type": "text"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "isActive": true,
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MessagesIntent/draftMessage"
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Start a message.” or “Draft a message.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "isActive": true,
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MessagesIntent/sendMessage",
                      "type": "reference"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Send a message to John asking what time the party starts.” or “Text the foodie group and ask, ‘What time is dinner again?’”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "isActive": true,
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MessagesIntent/editSentMessage"
                    }
                  ]
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "text": "“Edit my last message.” or “Edit my last message to say ‘Good morning!’ instead of ‘Hello!’”",
                      "type": "text"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MessagesIntent/unsendMessage",
                      "isActive": true
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Unsend my last message.” or “Unsend that.”"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "isActive": true,
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MessagesIntent/setMessageReadStatus",
                      "type": "reference"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "text": "“Mark this message as unread.” or “Mark the message from the lawyer as unread.”",
                      "type": "text"
                    }
                  ]
                }
              ]
            ]
          ]
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "At build time, Xcode validates whether your app implements all the schemas in the group.",
              "type": "text"
            }
          ]
        },
        {
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "code": "messages_",
                  "type": "codeVoice"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ]
            }
          ],
          "style": "tip",
          "type": "aside",
          "name": "Tip"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "For more information about making your app’s actions available to Apple Intelligence and Siri, see "
            },
            {
              "type": "reference",
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/apple-intelligence-and-siri-ai"
            },
            {
              "text": ".",
              "type": "text"
            }
          ]
        }
      ],
      "kind": "content"
    }
  ],
