      "content": [
        {
          "anchor": "Overview",
          "text": "Overview",
          "type": "heading",
          "level": 2
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "Indexing your app’s content makes that content findable during searches, and also helps Siri"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "and other system features locate app-specific data. If you create entities for your app’s",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "data, index those entities as part of your content. When a search finds your content, the"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "system can use the associated entity to open your app and navigate to that content."
            }
          ]
        }
      ]
    }
  ],
  "abstract": [
    {
      "type": "text",
      "text": "Add your entities to your app’s Spotlight index, and automate the indexing of your content."
    }
  ],
