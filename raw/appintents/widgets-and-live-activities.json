  "abstract": [
    {
      "text": "Use app intents make your widgets and Live Activities interactive, offer controls, and suggest widgets in Smart Stacks.",
      "type": "text"
    }
  ],
  "seeAlsoSections": [
    {
      "anchor": "System-experiences",
      "title": "System experiences",
      "generated": true,
