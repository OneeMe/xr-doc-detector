  "primaryContentSections": [
    {
      "content": [
        {
          "type": "heading",
          "anchor": "overview",
          "level": 2,
          "text": "Overview"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "App Intents allows you to bring additional functionality to widgets and Live Activites, and are key to offering controls. While widgets offer personalization and glanceable information, Live Activities display up-to-date information, and controls allow people to perform actions in Control Center, on the Lock Screen, or from the Action button. Each feature uses "
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.documentation/documentation/WidgetKit"
            },
            {
              "type": "text",
              "text": ", and Live Activities additionally use "
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.documentation/documentation/ActivityKit",
              "isActive": true
            },
            {
              "type": "text",
              "text": ". With App Intents, you can:"
            }
          ]
        },
        {
          "items": [
            {
              "content": [
                {
                  "inlineContent": [
                    {
                      "text": "Provide hints to the system so it can automatically suggest widgets in Smart Stacks.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "content": [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Add interactive buttons or toggles to widgets and Live Activities."
                    }
                  ]
                }
              ]
            },
            {
              "content": [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Create interactive controls that people place in Control Center, on the Lock Screen, or on the Action button."
                    }
                  ]
                }
              ]
            }
          ],
          "type": "unorderedList"
        }
      ],
      "kind": "content"
    }
  ],
