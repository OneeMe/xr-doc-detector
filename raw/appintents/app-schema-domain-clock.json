  "primaryContentSections": [
    {
      "content": [
        {
          "type": "heading",
          "text": "Overview",
          "anchor": "overview",
          "level": 2
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "code": ".clock",
              "type": "codeVoice"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "structured representation for common alarm and timer actions and content."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "Apply schemas in the ",
              "type": "text"
            },
            {
              "code": ".clock",
              "type": "codeVoice"
            },
            {
              "text": " domain to make your app’s clock functionality available to Apple Intelligence and Siri.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "Each schema defines the requirements for intents, parameters, and results so people get a consistent experience across clock apps.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "For example, a person can set an alarm on different apps that support the",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/createAlarm",
              "type": "reference"
            },
            {
              "text": " schema with the same phrases.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The following table maps example phrases that apply to each schema."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Your app needs to support all of these schemas when it supports any one of them."
            }
          ]
        },
        {
          "type": "table",
          "rows": [
            [
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Clock intent schemas"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "Example phrases",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "reference",
                      "isActive": true,
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/createAlarm"
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Set an alarm.” or “Wake me up at 7 AM.”"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/updateAlarm",
                      "isActive": true
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Change my alarm.” or “Change the 7 AM alarm to 8 AM.”"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/snoozeAlarm",
                      "isActive": true,
                      "type": "reference"
                    }
                  ]
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Snooze.” or “Give me 5 more minutes.”"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/dismissAlarm",
                      "isActive": true,
                      "type": "reference"
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Dismiss the alarm.” or “Stop the alarm.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/deleteAlarm",
                      "isActive": true,
                      "type": "reference"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Delete my alarm.” or “Remove the 7 AM alarm.”"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/createTimer",
                      "type": "reference",
                      "isActive": true
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Set a timer.” or “Timer for 5 minutes.”"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/updateTimer",
                      "isActive": true
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Add 5 minutes to the timer.” or “Change the timer to 10 minutes.”"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/pauseTimer",
                      "type": "reference",
                      "isActive": true
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Pause the timer.”"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/resumeTimer",
                      "isActive": true,
                      "type": "reference"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Resume the timer.” or “Start the timer again.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "reference",
                      "isActive": true,
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/ClockIntent/cancelTimer"
                    }
                  ]
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Cancel the timer.” or “Stop the timer.”"
                    }
                  ]
                }
              ]
            ]
          ],
          "header": "row"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "At build time, Xcode validates whether your app implements all the schemas in the group."
            }
          ]
        },
        {
          "style": "tip",
          "name": "Tip",
          "content": [
            {
              "inlineContent": [
                {
                  "type": "text",
                  "text": "Xcode generates a template implementation when you type "
                },
                {
                  "type": "codeVoice",
                  "code": "clock_"
                },
                {
                  "text": " and select a schema from the suggestions list.",
                  "type": "text"
                }
              ],
              "type": "paragraph"
            }
          ],
          "type": "aside"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "For more information about making your app’s actions available to Apple Intelligence and Siri, see "
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/apple-intelligence-and-siri-ai"
            },
            {
              "text": ".",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
