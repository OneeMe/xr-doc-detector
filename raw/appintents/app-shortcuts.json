    "doc://com.apple.AppIntents/documentation/AppIntents/NegativeAppShortcutPhrases": {
      "title": "NegativeAppShortcutPhrases",
      "url": "https://developer.apple.com/documentation/appintents/negativeappshortcutphrases",
      "abstract": [
        {
          "type": "text",
          "text": "This is a set of negative phrases, which will all be added to the app-level negative"
        },
        {
          "text": " ",
          "type": "text"
        },
        {
          "text": "training set. All the training data specified here, will be used to completely bypass your app",
          "type": "text"
        }
      ],
      "role": "symbol",
      "type": "topic",
      "kind": "symbol",
      "fragments": [
        {
          "text": "struct",
          "kind": "keyword"
