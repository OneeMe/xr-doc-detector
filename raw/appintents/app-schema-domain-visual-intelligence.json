  "abstract": [
    {
      "text": "Display search results from your app when people point the camera at relevant content.",
      "type": "text"
    }
  ],
  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "level": 2,
          "text": "Overview",
          "anchor": "overview",
          "type": "heading"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "code": ".visualIntelligence",
              "type": "codeVoice"
            },
            {
              "type": "text",
              "text": " domain defines app schemas that connect your app to the camera control."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Apply the "
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/VisualIntelligenceIntent/semanticContentSearch",
              "isActive": true
            },
            {
              "type": "text",
              "text": " schema to make your app appear as a search destination in Visual Intelligence."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "The "
            },
            {
              "type": "reference",
              "isActive": true,
              "identifier": "doc://com.apple.documentation/documentation/VisualIntelligence"
            },
            {
              "text": " framework provides the types that describe what visual intelligence captures from the camera or a screenshot.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Your app implements an "
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/IntentValueQuery"
            },
            {
              "text": " to receive these types, find matching content, and return app entities.",
              "type": "text"
            }
          ]
        },
        {
          "type": "aside",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "code": "visualIntelligence_",
                  "type": "codeVoice"
                },
                {
                  "text": " and select a schema from the suggestions list.",
                  "type": "text"
                }
              ]
            }
          ],
          "style": "tip",
          "name": "Tip"
        }
      ]
    }
  ],
