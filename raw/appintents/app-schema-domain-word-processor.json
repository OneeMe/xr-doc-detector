{
  "abstract": [
    {
      "type": "text",
      "text": "Make your word processor’s actions available in the Shortcuts app by adopting schemas for document editing."
    }
  ],
  "primaryContentSections": [
    {
      "content": [
        {
          "text": "Overview",
          "anchor": "overview",
          "type": "heading",
          "level": 2
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "type": "codeVoice",
              "code": ".wordProcessor"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "structured representation for common document editing actions and content."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "code": ".wordProcessor",
              "type": "codeVoice"
            },
            {
              "text": " domain to make your word processor’s functionality available as actions in the Shortcuts app.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "Schemas in this domain don’t make your conforming types discoverable by Apple Intelligence and Siri.",
              "type": "text"
            }
          ]
        },
        {
          "type": "aside",
          "name": "Tip",
          "style": "tip",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "type": "text",
                  "text": "Xcode generates a template implementation when you type "
                },
                {
                  "code": "wordProcessor_",
                  "type": "codeVoice"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ]
            }
          ]
        },
        {
          "inlineContent": [
            {
              "text": "For more information about app schemas, see ",
              "type": "text"
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/app-schema-domains",
              "isActive": true
            },
            {
              "text": ".",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
