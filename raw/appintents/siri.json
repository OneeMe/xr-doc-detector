  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "level": 2,
          "type": "heading",
          "anchor": "overview",
          "text": "Overview"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "Apple Intelligence is a new personal intelligence system that deeply integrates powerful generative models into the core of iPhone, iPad and Mac. Siri will draw on the capabilities of Apple Intelligence to deliver assistance that’s more natural, contextually relevant and personal to users."
            }
          ],
          "type": "paragraph"
        },
        {
          "style": "note",
          "name": "Note",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Siri’s personal context understanding, onscreen awareness, and in-app actions are in development and will be available with a future software update.",
                  "type": "text"
                }
              ]
            }
          ],
          "type": "aside"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "A big part of people’s personal context are the apps they use every day. The App Intents framework gives you a means to express your app’s capabilities and content to the system and integrate them with Siri and Apple Intelligence. This will unlock new ways for your users to interact with your app from anywhere on their device.",
              "type": "text"
            }
          ]
        },
        {
          "content": [
            {
              "inlineContent": [
                {
                  "text": "If you’re new to the App Intents framework, make sure to read ",
                  "type": "text"
                },
                {
                  "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/Making-actions-and-content-discoverable-and-widely-available",
                  "type": "reference",
                  "isActive": true
                },
                {
                  "type": "text",
                  "text": " and "
                },
                {
                  "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/Creating-your-first-app-intent",
                  "type": "reference",
                  "isActive": true
                },
                {
                  "type": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            }
          ],
          "style": "note",
          "type": "aside",
          "name": "Note"
        }
      ]
    }
  ],
