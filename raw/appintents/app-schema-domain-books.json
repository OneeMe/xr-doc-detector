  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "text": "Overview",
          "anchor": "overview",
          "type": "heading",
          "level": 2
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "The ",
              "type": "text"
            },
            {
              "type": "codeVoice",
              "code": ".books"
            },
            {
              "type": "text",
              "text": " domain defines app schemas that provide a"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "structured representation for common reading actions and content."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "code": ".books",
              "type": "codeVoice"
            },
            {
              "text": " domain to make your ebook reader’s functionality available as actions in the Shortcuts app.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Schemas in this domain don’t make your conforming types discoverable by Apple Intelligence and Siri."
            }
          ]
        },
        {
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "code": "books_",
                  "type": "codeVoice"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ]
            }
          ],
          "type": "aside",
          "name": "Tip",
          "style": "tip"
        },
        {
          "inlineContent": [
            {
              "text": "For more information about app schemas, see ",
              "type": "text"
            },
            {
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/app-schema-domains",
              "type": "reference",
              "isActive": true
            },
            {
              "type": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ]
    }
  ],
