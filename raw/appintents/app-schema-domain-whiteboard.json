  "primaryContentSections": [
    {
      "content": [
        {
          "level": 2,
          "anchor": "overview",
          "type": "heading",
          "text": "Overview"
        },
        {
          "inlineContent": [
            {
              "text": "The ",
              "type": "text"
            },
            {
              "type": "codeVoice",
              "code": ".whiteboard"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "structured representation for common whiteboard actions and content."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "type": "codeVoice",
              "code": ".whiteboard"
            },
            {
              "type": "text",
              "text": " domain to make your app’s whiteboard functionality available as actions in the Shortcuts app."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Schemas in this domain don’t make your conforming types discoverable by Apple Intelligence and Siri."
            }
          ],
          "type": "paragraph"
        },
        {
          "style": "tip",
          "type": "aside",
          "name": "Tip",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "code": "whiteboard_",
                  "type": "codeVoice"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ]
            }
          ]
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "For more information about app schemas, see ",
              "type": "text"
            },
            {
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/app-schema-domains",
              "isActive": true,
              "type": "reference"
            },
            {
              "type": "text",
              "text": "."
            }
          ]
        }
      ],
      "kind": "content"
    }
  ],
