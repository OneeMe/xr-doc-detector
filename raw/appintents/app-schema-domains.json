  "abstract": [
    {
      "type": "text",
      "text": "Declare support for well-known actions and content by applying system-defined schemas to"
    },
    {
      "type": "text",
      "text": " "
    },
    {
      "text": "your app intents, app entities, and app enumerations.",
      "type": "text"
    }
  ],
  "primaryContentSections": [
    {
      "content": [
        {
          "level": 2,
          "type": "heading",
          "text": "Overview",
          "anchor": "Overview"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "Help the system correctly understand your app and its intents, entities, and enumerations",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "by conforming your types to system-defined schemas whenever possible."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Each schema tells the system how to interpret one of your app’s types."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "For example, when an email app conforms one of its intents to the "
            },
            {
              "type": "codeVoice",
              "code": ".mail.createDraft"
            },
            {
              "type": "text",
              "text": " schema, the"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "system knows it can invoke that intent to create a new email draft in that app."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "This information enhances the system’s understanding of your app’s content and helps facilitate interactions",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "with Siri, Apple Intelligence, and other system features."
            }
          ]
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "To apply a schema to one of your types, add one of the following macros ahead of its declaration:"
            }
          ]
        },
        {
          "items": [
            {
              "content": [
                {
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppIntent(schema:)",
                      "isActive": true,
                      "type": "reference"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "content": [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppEntity(schema:)",
                      "isActive": true,
                      "type": "reference"
                    }
                  ]
                }
              ]
            },
            {
              "content": [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "isActive": true,
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppEnum(schema:)"
                    }
                  ]
                }
              ]
            }
          ],
          "type": "unorderedList"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "When you build your app, these macros expand and map the type to the schema you assign to it."
            }
          ],
          "type": "paragraph"
        },
        {
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Increase the number of your app’s actions that people can invoke with Apple Intelligence and Siri by adopting optional schemas.",
                  "type": "text"
                }
              ]
            }
          ],
          "style": "tip",
          "name": "Tip",
          "type": "aside"
        }
      ],
      "kind": "content"
    }
  ],
