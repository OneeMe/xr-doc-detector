  "primaryContentSections": [
    {
      "content": [
        {
          "text": "Overview",
          "type": "heading",
          "anchor": "Overview",
          "level": 2
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "Create an app extension to run your custom app intents when your app isn’t running."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "To make it easier to share your intent code between your app and app extension, you"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "can also place that code in a Swift package and import it into each target.",
              "type": "text"
            }
          ]
        }
      ],
      "kind": "content"
    }
  ],
