  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "type": "heading",
          "text": "Overview",
          "level": 2,
          "anchor": "overview"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "type": "codeVoice",
              "code": ".reminders"
            },
            {
              "type": "text",
              "text": " domain defines app schemas that provide a"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "structured representation for common reminder actions and content.",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "Apply schemas in the ",
              "type": "text"
            },
            {
              "type": "codeVoice",
              "code": ".reminders"
            },
            {
              "text": " domain to make your app’s reminder functionality available to Apple Intelligence and Siri.",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "Each schema defines the requirements for intents, parameters, and results so people get a consistent experience across reminder apps.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "For example, a person can create a reminder on different apps that support the"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/RemindersIntent/createReminder",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": " schema with the same phrases.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "The following table maps example phrases that apply to each schema:",
              "type": "text"
            }
          ]
        },
        {
          "type": "table",
          "header": "row",
          "rows": [
            [
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Reminders intent schemas"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "text": "Example phrases",
                      "type": "text"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "isActive": true,
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/RemindersIntent/createList"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Create a list called shopping.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "isActive": true,
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/RemindersIntent/createReminder",
                      "type": "reference"
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Create a reminder.” or “Create a reminder called vote.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/RemindersIntent/createSection",
                      "type": "reference",
                      "isActive": true
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "text": "“Create a section called vegetables.”",
                      "type": "text"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/RemindersIntent/deleteReminders",
                      "isActive": true
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Delete this reminder.”"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/RemindersIntent/updateReminder",
                      "isActive": true,
                      "type": "reference"
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Mark this reminder as completed.” or “Set the due date for this reminder to tomorrow.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ]
          ]
        },
        {
          "style": "tip",
          "type": "aside",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "type": "text",
                  "text": "Xcode generates a template implementation when you type "
                },
                {
                  "type": "codeVoice",
                  "code": "reminders_"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ]
            }
          ],
          "name": "Tip"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "For more information about making your app’s actions available to Apple Intelligence and Siri, see "
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/apple-intelligence-and-siri-ai"
            },
            {
              "text": ".",
              "type": "text"
            }
          ]
        }
      ]
    }
  ],
