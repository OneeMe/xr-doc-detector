  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "text": "Overview",
          "type": "heading",
          "level": 2,
          "anchor": "overview"
        },
        {
          "inlineContent": [
            {
              "text": "The ",
              "type": "text"
            },
            {
              "type": "codeVoice",
              "code": ".maps"
            },
            {
              "type": "text",
              "text": " domain defines app schemas that provide a"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "structured representation for common navigation actions and content.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "type": "codeVoice",
              "code": ".maps"
            },
            {
              "type": "text",
              "text": " domain to make your app’s navigation functionality available to Apple Intelligence and Siri."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Each schema defines the requirements for intents, parameters, and results so people get a consistent experience across navigation apps."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "For example, a person can start a route on different apps that support the",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "reference",
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MapsIntent/startNavigation"
            },
            {
              "text": " schema with the same phrases.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "The following table maps example phrases that apply to each schema:",
              "type": "text"
            }
          ]
        },
        {
          "rows": [
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Maps intent schemas"
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Example phrases"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MapsIntent/startNavigation",
                      "isActive": true
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Navigate to work.” or “Take me home.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "isActive": true,
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MapsIntent/stopNavigation"
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Stop navigation.” or “Cancel directions.”"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "isActive": true,
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MapsIntent/addNavigationWaypoints",
                      "type": "reference"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "text": "“Add a stop.” or “Add coffee kiosk as a waypoint.”",
                      "type": "text"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "isActive": true,
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MapsIntent/shareETA",
                      "type": "reference"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Share my ETA.” or “Send my ETA to Anne.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "isActive": true,
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MapsIntent/stopShareETA"
                    }
                  ]
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "text": "“Stop sharing my ETA.”",
                      "type": "text"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/MapsIntent/reportIncident",
                      "isActive": true
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Report an accident.” or “There’s a crash ahead.”"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ]
          ],
          "header": "row",
          "type": "table"
        },
        {
          "style": "tip",
          "type": "aside",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "code": "maps_",
                  "type": "codeVoice"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ]
            }
          ],
          "name": "Tip"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "For more information about making your app’s actions available to Apple Intelligence and Siri, see "
            },
            {
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/apple-intelligence-and-siri-ai",
              "type": "reference"
            },
            {
              "type": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ]
    }
  ],
