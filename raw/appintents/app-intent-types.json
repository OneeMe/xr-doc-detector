  "kind": "article",
  "abstract": [
    {
      "type": "text",
      "text": "Build your intents from types that define common behaviors such as opening or deleting"
    },
    {
      "text": " ",
      "type": "text"
    },
    {
      "type": "text",
      "text": "items, playing or recording media, and more."
    }
  ],
  "primaryContentSections": [
    {
      "content": [
        {
          "type": "heading",
          "anchor": "Overview",
          "text": "Overview",
          "level": 2
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "The app intents you create conform to the "
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppIntent",
              "isActive": true
            },
            {
              "type": "text",
              "text": " protocol for basic features, but you"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "can choose other protocols as an alternate starting point. You might choose a different protocol"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "for an intent that offers a specific behavior or supports a particular capability. For example,",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "use the ",
              "type": "text"
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/OpenIntent"
            },
            {
              "text": " protocol if your app intent launches your app and displays a specific item.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "These protocols also conform to the "
            },
            {
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppIntent",
              "type": "reference"
            },
            {
              "type": "text",
              "text": " protocol, giving you both the base features and"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "the additional behaviors you need for your specific app intent."
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
