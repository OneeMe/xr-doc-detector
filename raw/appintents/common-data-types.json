        {
          "anchor": "Overview",
          "text": "Overview",
          "type": "heading",
          "level": 2
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "When creating your app intents or app entities, use existing types for parameters and",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "properties whenever possible. The App Intents framework provides common data types to",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "represent people, files, currencies, and more. Choose the type that matches your app’s"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "data and fill its properties with data from your app.",
              "type": "text"
            }
          ]
        }
      ],
      "kind": "content"
    }
  ],
