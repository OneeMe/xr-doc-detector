  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "level": 2,
          "type": "heading",
          "text": "Overview",
          "anchor": "overview"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "code": ".files",
              "type": "codeVoice"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "structured representation for common file actions and content."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "type": "codeVoice",
              "code": ".files"
            },
            {
              "text": " domain to make your app’s file management functionality available to Apple Intelligence and Siri.",
              "type": "text"
            }
          ]
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The following table maps example phrases that apply to each schema:"
            }
          ]
        },
        {
          "type": "table",
          "header": "row",
          "rows": [
            [
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Files intent schemas"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "text": "Example phrases",
                      "type": "text"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "isActive": true,
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/FilesIntent/renameFile"
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Rename this file.” or “Rename document.txt to report.txt.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ]
          ]
        },
        {
          "name": "Tip",
          "type": "aside",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "type": "text",
                  "text": "Xcode generates a template implementation when you type "
                },
                {
                  "code": "files_",
                  "type": "codeVoice"
                },
                {
                  "text": " and select a schema from the suggestions list.",
                  "type": "text"
                }
              ]
            }
          ],
          "style": "tip"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "For more information about making your app’s actions available to Apple Intelligence and Siri, see "
            },
            {
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/apple-intelligence-and-siri-ai",
              "isActive": true,
              "type": "reference"
            },
            {
              "type": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ]
    }
  ],
