      "content": [
        {
          "level": 2,
          "text": "Overview",
          "type": "heading",
          "anchor": "overview"
        },
        {
          "inlineContent": [
            {
              "text": "The ",
              "type": "text"
            },
            {
              "code": ".assistant",
              "type": "codeVoice"
            },
            {
              "type": "text",
              "text": " domain defines a single app intent schema, "
            },
            {
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/AssistantIntent/activate",
              "type": "reference"
            },
            {
              "type": "text",
              "text": ", that registers your app as a side button action on iPhone."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "This schema is available only in Japan.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "style": "tip",
          "content": [
            {
              "inlineContent": [
                {
                  "type": "text",
                  "text": "Xcode generates a template implementation when you type "
                },
                {
                  "code": "assistant_",
                  "type": "codeVoice"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ],
              "type": "paragraph"
            }
          ],
          "name": "Tip",
          "type": "aside"
        },
        {
          "inlineContent": [
            {
              "text": "For more information about app schemas, see ",
              "type": "text"
            },
            {
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/app-schema-domains",
              "isActive": true,
              "type": "reference"
            },
            {
              "type": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ]
    }
