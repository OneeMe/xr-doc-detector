  "primaryContentSections": [
    {
      "content": [
        {
          "text": "Overview",
          "level": 2,
          "anchor": "Overview",
          "type": "heading"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "To enable enhanced understanding and more conversational interactions with Siri for your app, choose a domain and a schema that match your app’s functionality. By conforming your app intent, app entity, or your app enumeration to a schema, you ensure that Apple Intelligence understands your app’s actions and content. When you’ve identified the schema to use, leverage the ",
              "type": "text"
            },
            {
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppIntent(schema:)",
              "isActive": true,
              "type": "reference"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppEntity(schema:)",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": ", and ",
              "type": "text"
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppEnum(schema:)"
            },
            {
              "type": "text",
              "text": " macros to write schema-conforming code."
            }
          ]
        },
        {
          "name": "Note",
          "type": "aside",
          "style": "note",
          "content": [
            {
              "inlineContent": [
                {
                  "type": "text",
                  "text": "Siri’s personal context understanding, onscreen awareness, and in-app actions are in development and will be available with a future software update."
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "inlineContent": [
            {
              "text": "To learn more, refer to ",
              "type": "text"
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/Integrating-actions-with-siri-and-apple-intelligence",
              "isActive": true
            },
            {
              "type": "text",
              "text": " and "
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/Making-onscreen-content-available-to-siri-and-apple-intelligence",
              "isActive": true
            },
            {
              "text": ".",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
