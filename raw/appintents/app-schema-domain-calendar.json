  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "type": "heading",
          "text": "Overview",
          "level": 2,
          "anchor": "overview"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "type": "codeVoice",
              "code": ".calendar"
            },
            {
              "type": "text",
              "text": " domain defines app schemas that provide a"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "structured representation for common calendar actions and content."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "Apply schemas in the ",
              "type": "text"
            },
            {
              "code": ".calendar",
              "type": "codeVoice"
            },
            {
              "text": " domain to make your app’s calendar functionality available to Apple Intelligence and Siri.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "The following table maps example phrases that apply to each schema:",
              "type": "text"
            }
          ]
        },
        {
          "header": "row",
          "type": "table",
          "rows": [
            [
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Calendar intent schemas"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "Example phrases"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/CalendarIntent/createEvent",
                      "type": "reference",
                      "isActive": true
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Create an event.” or “Schedule a meeting with Bill tomorrow at 2 PM.”"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/CalendarIntent/deleteEvents",
                      "isActive": true
                    }
                  ]
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Delete this event.” or “Cancel the meeting.”"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "isActive": true,
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/CalendarIntent/updateEvent",
                      "type": "reference"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Reschedule the meeting.” or “Move the meeting to tomorrow.”"
                    }
                  ]
                }
              ]
            ]
          ]
        },
        {
          "name": "Tip",
          "type": "aside",
          "style": "tip",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "type": "codeVoice",
                  "code": "calendar_"
                },
                {
                  "text": " and select a schema from the suggestions list.",
                  "type": "text"
                }
              ]
            }
          ]
        },
        {
          "inlineContent": [
            {
              "text": "For more information about making your app’s actions available to Apple Intelligence and Siri, see ",
              "type": "text"
            },
            {
              "type": "reference",
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/apple-intelligence-and-siri-ai"
            },
            {
              "text": ".",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ]
    }
  ],
