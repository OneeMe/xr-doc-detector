  "primaryContentSections": [
    {
      "content": [
        {
          "level": 2,
          "anchor": "overview",
          "text": "Overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "The ",
              "type": "text"
            },
            {
              "code": ".phone",
              "type": "codeVoice"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "structured representation for common calling actions and content.",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "Apply schemas in the ",
              "type": "text"
            },
            {
              "code": ".phone",
              "type": "codeVoice"
            },
            {
              "type": "text",
              "text": " domain to make your app’s phone functionality available to Apple Intelligence and Siri."
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "definition": {
                "content": [
                  {
                    "type": "paragraph",
                    "inlineContent": [
                      {
                        "text": "An intent that starts calls when people say phrases like “Make a call to Bill.” or “Video call Bill and Maria.”",
                        "type": "text"
                      }
                    ]
                  }
                ]
              },
              "term": {
                "inlineContent": [
                  {
                    "type": "reference",
                    "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/PhoneIntent/startCall",
                    "isActive": true
                  }
                ]
              }
            }
          ],
          "type": "termList"
        },
        {
          "style": "tip",
          "name": "Tip",
          "type": "aside",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "code": "phone_",
                  "type": "codeVoice"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ]
            }
          ]
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "For more information about making your app’s actions available to Apple Intelligence and Siri, see "
            },
            {
              "type": "reference",
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/apple-intelligence-and-siri-ai"
            },
            {
              "type": "text",
              "text": "."
            }
          ]
        }
      ],
      "kind": "content"
    }
  ],
