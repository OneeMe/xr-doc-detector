  "primaryContentSections": [
    {
      "content": [
        {
          "text": "Overview",
          "level": 2,
          "anchor": "overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "code": ".camera",
              "type": "codeVoice"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "structured representation for common camera actions and content.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "type": "codeVoice",
              "code": ".camera"
            },
            {
              "type": "text",
              "text": " domain to make your app’s camera functionality available to Apple Intelligence and Siri."
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "The following table maps example phrases that apply to each schema:",
              "type": "text"
            }
          ]
        },
        {
          "header": "row",
          "rows": [
            [
              [
                {
                  "inlineContent": [
                    {
                      "text": "Camera intent schemas",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "Example phrases",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/CameraIntent/openInCaptureMode",
                      "isActive": true
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Open the camera.” or “Take a photo.”"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "isActive": true,
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/CameraIntent/switchDevice"
                    }
                  ]
                }
              ],
              [
                {
                  "type": "paragraph",
                  "inlineContent": [
                    {
                      "type": "text",
                      "text": "“Flip the camera.” or “Turn the camera.”"
                    }
                  ]
                }
              ]
            ],
            [
              [
                {
                  "inlineContent": [
                    {
                      "isActive": true,
                      "type": "reference",
                      "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/CameraIntent/startCapture"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              [
                {
                  "inlineContent": [
                    {
                      "text": "“Start recording.” or “Record a video.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            ]
          ],
          "type": "table"
        },
        {
          "style": "tip",
          "name": "Tip",
          "content": [
            {
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "type": "codeVoice",
                  "code": "camera_"
                },
                {
                  "text": " and select a schema from the suggestions list.",
                  "type": "text"
                }
              ],
              "type": "paragraph"
            }
          ],
          "type": "aside"
        },
        {
          "inlineContent": [
            {
              "text": "For more information about making your app’s actions available to Apple Intelligence and Siri, see ",
              "type": "text"
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/apple-intelligence-and-siri-ai",
              "isActive": true
            },
            {
              "type": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
