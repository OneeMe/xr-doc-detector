  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "level": 2,
          "text": "Overview",
          "type": "heading",
          "anchor": "overview"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "type": "codeVoice",
              "code": ".notes"
            },
            {
              "text": " domain defines app schemas that provide a",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "structured representation for common note actions and content."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "code": ".notes",
              "type": "codeVoice"
            },
            {
              "type": "text",
              "text": " domain to make your app’s note-taking functionality available to Apple Intelligence and Siri."
            }
          ]
        },
        {
          "items": [
            {
              "term": {
                "inlineContent": [
                  {
                    "type": "reference",
                    "isActive": true,
                    "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/NotesIntent/createNote"
                  }
                ]
              },
              "definition": {
                "content": [
                  {
                    "inlineContent": [
                      {
                        "text": "An intent that creates notes when people say phrases like “Create a note called meeting notes.”",
                        "type": "text"
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              }
            },
            {
              "definition": {
                "content": [
                  {
                    "type": "paragraph",
                    "inlineContent": [
                      {
                        "type": "text",
                        "text": "An intent that updates notes when people say phrases like “Rename this note to taxes.” or “Move this note to my work folder.”"
                      }
                    ]
                  }
                ]
              },
              "term": {
                "inlineContent": [
                  {
                    "type": "reference",
                    "isActive": true,
                    "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/NotesIntent/updateNote"
                  }
                ]
              }
            }
          ],
          "type": "termList"
        },
        {
          "style": "tip",
          "name": "Tip",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "type": "text",
                  "text": "Xcode generates a template implementation when you type "
                },
                {
                  "code": "notes_",
                  "type": "codeVoice"
                },
                {
                  "text": " and select a schema from the suggestions list.",
                  "type": "text"
                }
              ]
            }
          ],
          "type": "aside"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "For more information about making your app’s actions available to Apple Intelligence and Siri, see "
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/apple-intelligence-and-siri-ai"
            },
            {
              "type": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ]
    }
  ],
