  "abstract": [
    {
      "type": "text",
      "text": "Integrate your app with visual intelligence and include your content in its search results."
    }
  ],
  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "anchor": "overview",
          "text": "Overview",
          "level": 2,
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "People use visual intelligence to learn about places and objects around them and onscreen. To integrate your app with visual intelligence and include your app’s content in search results, use the "
            },
            {
              "identifier": "doc://com.apple.documentation/documentation/VisualIntelligence",
              "isActive": true,
              "type": "reference"
            },
            {
              "type": "text",
              "text": " framework to receive information captured by visual intelligence and use App Intents and an "
            },
            {
              "isActive": true,
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/IntentValueQuery",
              "type": "reference"
            },
            {
              "text": " to return matching content.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ]
    }
  ],
