  "primaryContentSections": [
    {
      "content": [
        {
          "text": "Overview",
          "anchor": "Overview",
          "level": 2,
          "type": "heading"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "People use visual intelligence to learn about the places and objects they see in their environment"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "or on their device. To assist with item identification, the system asks apps to match their"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "content against the images it provides. If an app finds a match, the system displays that match"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "in the visual search results so people can navigate to the app for more information. The system"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "relies on app intents to perform searches and open any search results."
            }
          ]
        }
      ],
      "kind": "content"
    }
  ],
