  "primaryContentSections": [
    {
      "content": [
        {
          "anchor": "overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The "
            },
            {
              "code": ".system",
              "type": "codeVoice"
            },
            {
              "type": "text",
              "text": " domain defines app schemas that provide a"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "structured representation for common search actions and content.",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "code": ".system",
              "type": "codeVoice"
            },
            {
              "text": " domain to make your app’s search and content access available to Apple Intelligence and Siri.",
              "type": "text"
            }
          ]
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "Unlike other domains that target a specific app category, the "
            },
            {
              "type": "codeVoice",
              "code": ".system"
            },
            {
              "type": "text",
              "text": " domain applies broadly."
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "type": "text",
              "text": "Any app that enables searching or opening content can adopt these schemas."
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "termList",
          "items": [
            {
              "term": {
                "inlineContent": [
                  {
                    "type": "reference",
                    "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/SystemIntent/search",
                    "isActive": true
                  }
                ]
              },
              "definition": {
                "content": [
                  {
                    "type": "paragraph",
                    "inlineContent": [
                      {
                        "text": "An intent that searches in your app when people say phrases like “Find bicycle.” or “Search for mountains.”",
                        "type": "text"
                      }
                    ]
                  }
                ]
              }
            },
            {
              "term": {
                "inlineContent": [
                  {
                    "isActive": true,
                    "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/AppSchema/SystemIntent/open",
                    "type": "reference"
                  }
                ]
              },
              "definition": {
                "content": [
                  {
                    "type": "paragraph",
                    "inlineContent": [
                      {
                        "type": "text",
                        "text": "An intent that opens content in your app when people say phrases like “Open my screenshot.png file.”"
                      }
                    ]
                  }
                ]
              }
            }
          ]
        },
        {
          "content": [
            {
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "type": "codeVoice",
                  "code": "system_"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ],
              "type": "paragraph"
            }
          ],
          "name": "Tip",
          "type": "aside",
          "style": "tip"
        },
        {
          "inlineContent": [
            {
              "text": "For more information about making your app’s actions available to Apple Intelligence and Siri, see ",
              "type": "text"
            },
            {
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/apple-intelligence-and-siri-ai",
              "isActive": true,
              "type": "reference"
            },
            {
              "text": ".",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
