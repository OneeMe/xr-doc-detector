  "abstract": [
    {
      "text": "Make your presentation app’s actions available in the Shortcuts app by adopting schemas for common presentation actions.",
      "type": "text"
    }
  ],
  "identifier": {
    "interfaceLanguage": "swift",
    "url": "doc://com.apple.AppIntents/documentation/AppIntents/app-schema-domain-presentation"
  },
  "primaryContentSections": [
    {
      "content": [
        {
          "anchor": "Overview",
          "text": "Overview",
          "type": "heading",
          "level": 2
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "The ",
              "type": "text"
            },
            {
              "code": ".presentation",
              "type": "codeVoice"
            },
            {
              "type": "text",
              "text": " domain defines app schemas that provide a"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "structured representation for common presentation actions and content.",
              "type": "text"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "Apply schemas in the "
            },
            {
              "type": "codeVoice",
              "code": ".presentation"
            },
            {
              "type": "text",
              "text": " domain to make your app’s presentation functionality available as actions in the Shortcuts app."
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "Schemas in this domain don’t make your conforming types discoverable by Apple Intelligence and Siri.",
              "type": "text"
            }
          ]
        },
        {
          "style": "tip",
          "name": "Tip",
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Xcode generates a template implementation when you type ",
                  "type": "text"
                },
                {
                  "type": "codeVoice",
                  "code": "presentation_"
                },
                {
                  "type": "text",
                  "text": " and select a schema from the suggestions list."
                }
              ]
            }
          ],
          "type": "aside"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "For more information about app schemas, see "
            },
            {
              "type": "reference",
              "identifier": "doc://com.apple.AppIntents/documentation/AppIntents/app-schema-domains",
              "isActive": true
            },
            {
              "text": ".",
              "type": "text"
            }
          ]
        }
      ],
      "kind": "content"
    }
  ],
