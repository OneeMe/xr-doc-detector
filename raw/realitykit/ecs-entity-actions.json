  "primaryContentSections": [
    {
      "kind": "content",
      "content": [
        {
          "type": "heading",
          "text": "Overview",
          "anchor": "Overview",
          "level": 2
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "Entity actions provide an easy way to change or animate parts of your scene,"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "text": "while also allowing you to influence the changes with your app state.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "For example, you can vary the size of an impulse you apply to an entity with ",
              "type": "text"
            },
            {
              "identifier": "doc://com.apple.RealityKit/documentation/RealityKit/ImpulseAction",
              "isActive": true,
              "type": "reference"
            },
            {
              "type": "text",
              "text": ", play a sound at the end of an entity’s animation with "
            },
            {
              "isActive": true,
              "type": "reference",
              "identifier": "doc://com.apple.RealityKit/documentation/RealityKit/PlayAudioAction"
            },
            {
              "type": "text",
              "text": ", or create a custom action that changes your app state."
            }
          ]
        }
      ]
    }
  ],
