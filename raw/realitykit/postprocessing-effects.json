      "role": "symbol",
      "beta": true,
      "abstract": [
        {
          "text": "The ",
          "type": "text"
        },
        {
          "type": "codeVoice",
          "code": "BloomComponent"
        },
        {
          "text": " adds a luminous glow effect around bright objects in the scene",
          "type": "text"
        },
        {
          "type": "text",
          "text": " "
        },
        {
          "text": "by extracting and blurring the brightest parts of the image, then combining them",
          "type": "text"
        },
        {
          "type": "text",
          "text": " "
        },
        {
          "type": "text",
          "text": "back with the original rendering. If scope is set to "
        },
        {
          "type": "codeVoice",
          "code": "unbounded"
        },
        {
          "text": " Bloom will be computed",
          "type": "text"
        },
        {
          "text": " ",
          "type": "text"
        },
        {
          "type": "text",
          "text": "on the entire screen. If scope is set to "
        },
        {
          "code": "hierarchical",
          "type": "codeVoice"
        },
        {
          "type": "text",
          "text": " multiple Bloom Components can be"
        },
        {
          "type": "text",
          "text": " "
        },
        {
          "type": "text",
          "text": "used to opt in only the regions around certain objects for blooming."
        }
      ],
