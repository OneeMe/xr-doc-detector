{
  "abstract": [
    {
      "type": "text",
      "text": "Manage the simulated and physical devices that you use to test your app."
    }
  ],
  "seeAlsoSections": [
    {
      "identifiers": [
        "doc://com.apple.Xcode/documentation/Xcode/debugging",
